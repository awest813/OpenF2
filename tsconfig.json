{
    "compilerOptions": {
        "removeComments": true,
        "preserveConstEnums": true,
        "noImplicitReturns": true,
        "alwaysStrict": true, // emit "use strict"
        "skipLibCheck": true,
        "noImplicitAny": true,
        "noImplicitThis": true,
        "outDir": "js",
        "target": "es2021",
        "module": "esnext",
        "lib": ["es2021", "dom", "dom.iterable"],
        "allowJs": true
    },

    "include": ["src/**/*"],
    "exclude": ["node_modules", "src/**/*.test.ts", "src/testSetup.ts"]
}
